{
  "name": "@kiju/print-bridge",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/apps/print-bridge/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/apps/print-bridge/src/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/apps/print-bridge/src/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm,cjs && tsc -p tsconfig.json --declaration --emitDeclarationOnly",
    "dev": "tsup src/index.ts src/server.ts --format esm,cjs --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "corepack pnpm build && node --test test/**/*.test.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@kiju/domain": "workspace:*",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
