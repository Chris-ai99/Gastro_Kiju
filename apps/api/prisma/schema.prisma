generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model OperationalState {
  id        String   @id
  version   Int      @default(1)
  state     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionRecord {
  id             String   @id @default(cuid())
  transactionId  String   @unique
  deviceId       String
  actorId        String?
  kind           String
  payloadHash    String
  operation      Json
  confirmation   Json
  stateVersion   Int
  savedAt        DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([deviceId, createdAt])
  @@index([kind, createdAt])
}

model TransmissionAttempt {
  id            String    @id @default(cuid())
  transactionId String
  deviceId      String
  actorId       String?
  kind          String
  attemptNumber Int
  status        String
  response      Json?
  error         String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([transactionId, createdAt])
  @@index([status, createdAt])
}

model UndoCheckpoint {
  id            String    @id @default(cuid())
  kind          String
  transactionId String    @unique
  actorId       String?
  state         Json
  stateVersion  Int
  createdAt     DateTime  @default(now())
  usedAt        DateTime?

  @@index([kind, createdAt])
}

model PrinterConfig {
  id        String   @id
  version   Int      @default(1)
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrintJob {
  id            String    @id
  transactionId String
  requestHash   String
  request       Json
  status        String    @default("pending")
  attemptCount  Int       @default(0)
  lastAttemptAt DateTime?
  printedAt     DateTime?
  failedAt      DateTime?
  error         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([transactionId, requestHash])
  @@index([status, createdAt])
}
