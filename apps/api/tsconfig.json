{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "module": "CommonJS",
    "target": "ES2022",
    "outDir": "./dist",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "incremental": true,
    "strictPropertyInitialization": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {}
  },
  "include": ["src/**/*", "prisma/**/*"]
}
